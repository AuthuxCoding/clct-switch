#!/bin/bash
# CC Switch - Postinstall Script
# 安装后自动用用户本机证书签名

APP_PATH="/Applications/CC Switch.app"

echo "🔐 CC Switch: Signing with local certificate..."

# 移除 quarantine 标记
xattr -rd com.apple.quarantine "$APP_PATH" 2>/dev/null

# 尝试签名
if [ -f "$HOME/.cc-switch-cert" ]; then
    CERT=$(cat "$HOME/.cc-switch-cert")
    codesign --force --deep --sign "$CERT" "$APP_PATH" 2>/dev/null && echo "✅ Signed with: $CERT" && exit 0
fi

# 自动查找可用证书
AVAILABLE_CERT=$(security find-identity -v -p codesigning 2>/dev/null | grep -o '"[^"]*"' | head -1 | tr -d '"')

if [ -n "$AVAILABLE_CERT" ]; then
    codesign --force --deep --sign "$AVAILABLE_CERT" "$APP_PATH" 2>/dev/null && echo "✅ Signed with: $AVAILABLE_CERT" && exit 0
fi

# 没有证书就用 ad-hoc 签名
codesign --force --deep --sign - "$APP_PATH" 2>/dev/null && echo "✅ Ad-hoc signed" && exit 0

echo "⚠️ Could not sign. You may need to manually trust this app."
echo "   Open System Settings → Privacy & Security → Allow CC Switch"
exit 0
